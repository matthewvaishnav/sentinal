# SENTINEL Configuration

# Server
PORT=3000
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_WINDOW_MS=10000
RATE_LIMIT_MAX_REQUESTS=80
RATE_LIMIT_BLOCK_DURATION_MS=60000

# Fingerprinting
FINGERPRINT_BOT_THRESHOLD=3.0
FINGERPRINT_SUSPECT_THRESHOLD=5.5

# Challenges
CHALLENGE_DEFAULT_DIFFICULTY=2

# Allowlist (comma-separated)
ALLOWLIST_IPS=127.0.0.1,::1
ALLOWLIST_CIDRS=

# Trusted Proxies (comma-separated)
TRUSTED_PROXIES=127.0.0.1,::1

# Honeypot
HONEYPOT_TRAP_COUNT=40
HONEYPOT_ROTATE_INTERVAL_MS=3600000

# Contagion Graph
CONTAGION_SIMILARITY_THRESHOLD=0.75
CONTAGION_THRESHOLD=0.85
CONTAGION_MAX_NODES=10000

# API Authentication
# Generate secure keys with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Comma-separated list of API keys for admin endpoints
SENTINEL_API_KEYS=your_api_key_here,another_key_here
